{
  "name": "@enerthya/all",
  "version": "0.1.1",
  "description": "Bundle package — install everything with a single dependency",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "keywords": [
    "discord",
    "bot",
    "discord.js",
    "enerthya",
    "bundle",
    "monorepo"
  ],
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@enerthya/core": "^0.1.0",
    "@enerthya/utils": "^0.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Enerthya/enerthya-packages.git",
    "directory": "packages/all"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
